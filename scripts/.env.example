# Checkpoint Watchdog — RPC Configuration
#
# Copy this file to .env and set your paid RPC URLs.
# The .env file is gitignored and never committed.
#
# When indexers are far behind (>1000 blocks), the watchdog will
# restart them with the FAST RPCs for quick catch-up.
# When caught up (<100 blocks), it switches back to the FREE RPCs.

# ── Fast RPCs (paid, for catching up) ──
# Recommended: QuickNode, Infura, Alchemy, or similar
FAST_GNOSIS_RPC_URL=https://rpc.gnosischain.com
FAST_MAINNET_RPC_URL=https://eth.llamarpc.com

# Examples with paid providers:
# FAST_GNOSIS_RPC_URL=https://your-quicknode-endpoint.xdai.quiknode.pro/YOUR_API_KEY/
# FAST_MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_API_KEY
